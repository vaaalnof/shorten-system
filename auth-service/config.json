{
  "app": {
    "name": "auth-service"
  },

  "web": {
    "port": 3000,
    "prefork": false,

    "cors": {
      "allow_methods": "GET,POST,PUT,PATCH,DELETE,OPTIONS",
      "allow_headers": "Origin,Content-Type,Accept,Authorization",
      "allow_credentials": true
    }
  },

  "log": {
    "level": 6
  },

  "smtp": {
    "sender_name": "Shorten System",
    "sender_email": "noreply@yourapp.com"
  },

  "cache": {
    "session_ttl": 259200,
    "email_verification_ttl": 300,
    "email_verification_cooldown": 60,
    "oauth_state_ttl": 300
  },

  "jwt": {
    "access_token_expired": 900,
    "refresh_token_expired": 2592000
  },

  "rate_limit": {
    "login": {
      "max_attempts": 10,
      "window": 300
    },

    "register": {
      "max_attempts": 5,
      "window": 3600
    }
  }
}